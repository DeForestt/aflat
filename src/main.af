.needs <std>

import uni_string from "uni_string";

unique class Probe {
  mutable uni_string name = "";

  fn init(immutable adr name) -> Probe {
    my.name.copy_from(name);
    return my;
  };

  fn del() -> void {
    let name = my.name;
    delete name;
  };
};

fn main() -> int {
  let p = new Probe("John Doe");
  return 0;
};
