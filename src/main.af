.needs <std>

import uni_string from "uni_string";
import {print} from "uni_string" under uni;
import {printInt} from "io" under io;
fn main() {
    const uni_string deepChain = new uni_string("Chaining")
        .concat(new uni_string(" test"))
        .concat(` test2\n`);

    uni.print(deepChain);
};
