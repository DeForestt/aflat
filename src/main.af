.needs <std>

import uni_string from "uni_string";
import {print} from "uni_string" under uni;
import task from "Utils/Task";

async fn worker(task::<int> job) -> int {
  pause job.result = 41;
  return 42;
};

fn main() -> int {
  const task::<int> job = new task::<int>(worker);
  const int first = job.resume();
  const int result = job.resume();
  await job;
  uni.print(`first: {first}; second: {result}\n`);
  return result + first - 41;
};
